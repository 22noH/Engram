{
  "name": "engram-wiki-mcp",
  "version": "0.0.7",
  "productName": "Engram",
  "license": "AGPL-3.0-only",
  "description": "Engram — a self-hosted team knowledge wiki with semantic search, served as an MCP server. Propose-and-approve knowledge flow (human gate), shared data with the Engram desktop app.",
  "keywords": [
    "mcp",
    "mcp-server",
    "memory",
    "knowledge-base",
    "wiki",
    "semantic-search",
    "claude"
  ],
  "main": "dist/src/desktop/main.js",
  "bin": {
    "engram": "dist/src/cli.js",
    "engram-wiki-mcp": "dist/src/mcp-headless.js",
    "engram-server": "dist/src/server-cli.js"
  },
  "files": [
    "dist",
    "console/dist",
    "prompts",
    "personas",
    "README.md",
    "README.ko.md",
    "!dist/**/*.spec.js",
    "!dist/**/*.spec.js.map",
    "!dist/**/*.spec.d.ts",
    "!dist/tsconfig.tsbuildinfo"
  ],
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:cli": "ts-node src/cli.ts",
    "test": "jest",
    "demo": "ts-node scripts/demo.ts",
    "smoke:code": "node dist/src/cli.js code",
    "renderer:install": "npm --prefix renderer install",
    "renderer:build": "npm --prefix renderer run build",
    "desktop:dev": "npm run renderer:build && nest build && electron .",
    "desktop:build": "npm run renderer:build && npm run console:build && nest build && electron-builder",
    "console:install": "npm --prefix console install",
    "console:build": "npm --prefix console run build",
    "console:test": "npm --prefix console test"
  },
  "build": {
    "appId": "dev.engram.desktop",
    "productName": "Engram",
    "publish": {
      "provider": "github",
      "owner": "22noH",
      "repo": "Engram"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "prompts/**",
      "personas/**",
      "src/desktop/assets/**",
      "src/desktop/settings.html",
      "renderer/dist/**",
      "!node_modules/@huggingface/transformers/.cache/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/desktop/assets/icon.ico",
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**"
      ]
    },
    "mac": {
      "target": "dmg",
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**"
      ]
    },
    "linux": {
      "target": "AppImage",
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**"
      ]
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.30.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "apache-arrow": "^18.0.0",
    "chokidar": "^4.0.3",
    "cross-spawn": "^7.0.6",
    "discord.js": "^14.26.4",
    "electron-updater": "^6.8.9",
    "gray-matter": "^4.0.3",
    "lru-cache": "^11.5.1",
    "node-pty": "^1.1.0",
    "node-windows": "^1.0.0-beta.8",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "simple-git": "^3.27.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/node-windows": "^0.1.6",
    "@types/ws": "^8.18.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}

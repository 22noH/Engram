{
  "name": "engram",
  "version": "0.0.1",
  "private": true,
  "main": "dist/src/desktop/main.js",
  "bin": {
    "engram": "dist/src/cli.js"
  },
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:cli": "ts-node src/cli.ts",
    "test": "jest",
    "demo": "ts-node scripts/demo.ts",
    "smoke:code": "node dist/src/cli.js code",
    "desktop:dev": "nest build && electron .",
    "desktop:build": "nest build && electron-builder"
  },
  "build": {
    "appId": "dev.engram.desktop",
    "productName": "Engram",
    "directories": { "output": "release" },
    "files": [
      "dist/**",
      "prompts/**",
      "personas/**",
      "src/desktop/assets/**",
      "src/desktop/settings.html",
      "!node_modules/@huggingface/transformers/.cache/**"
    ],
    "win": {
      "target": "nsis",
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**"
      ]
    },
    "mac": {
      "target": "dmg",
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/linux/**"
      ]
    },
    "linux": {
      "target": "AppImage",
      "files": [
        "!node_modules/onnxruntime-node/bin/napi-v6/win32/**",
        "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**"
      ]
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.30.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "apache-arrow": "^18.0.0",
    "chokidar": "^4.0.3",
    "cross-spawn": "^7.0.6",
    "discord.js": "^14.26.4",
    "gray-matter": "^4.0.3",
    "lru-cache": "^11.5.1",
    "node-windows": "^1.0.0-beta.8",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.0",
    "@types/node-windows": "^0.1.6",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
